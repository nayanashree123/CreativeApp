# OpenAI API Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7

# Application Configuration
DEBUG=False
APP_NAME="Dream to Reality AI"
APP_VERSION=1.0.0

# Gradio UI Configuration
GRADIO_SHARE=0
GRADIO_DEBUG=0
GRADIO_SERVER_NAME=127.0.0.1
GRADIO_SERVER_PORT=7860

# Timeouts (seconds)
AGENT_TIMEOUT=200
ORCHESTRATOR_TIMEOUT=300

# Logging
LOG_LEVEL=INFO
LOG_FILE=

# RAG Configuration
KNOWLEDGE_BASE_PATH=knowledge
EMBEDDING_MODEL=text-embedding-3-small
MAX_RETRIEVED_DOCS=5

# Async Configuration
MAX_CONCURRENT_AGENTS=6

# LLM Provider Configuration
# Use "copilot" for free GitHub Copilot SDK (recommended) or "openai" for OpenAI API
LLM_PROVIDER=copilot
# GitHub Copilot Configuration (for free access via SDK)
GITHUB_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

GITHUB_ENTERPRISE_HOST=github.com
GITHUB_ENTERPRISE_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
COPILOT_MODEL=gpt-5-mini

COPILOT_TIMEOUT=200
COPILOT_RETRIES=2
COPILOT_TEMPERATURE=0.2